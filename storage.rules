rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Activity evidence files ───────────────────────────────────────────────
    // Path: activities/{activityId}/{fileName}
    // Matches what fileService.js generates via activityFilePath().
    match /activities/{activityId}/{fileName} {

      // Any authenticated staff member can download evidence files.
      allow read: if request.auth != null;

      // Authenticated users can upload. Enforces file size (10 MB) and
      // restricts to safe content types (images, PDFs, spreadsheets, Word docs).
      allow create: if request.auth != null
                    && request.resource.size <= 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf'
                        || request.resource.contentType == 'text/csv'
                        || request.resource.contentType == 'text/plain'
                        || request.resource.contentType.matches('application/vnd\\..*')
                        || request.resource.contentType.matches('application/msword.*'));

      // Allow replace/overwrite with same content-type restrictions.
      allow update: if request.auth != null
                    && request.resource.size <= 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf'
                        || request.resource.contentType == 'text/csv'
                        || request.resource.contentType == 'text/plain'
                        || request.resource.contentType.matches('application/vnd\\..*')
                        || request.resource.contentType.matches('application/msword.*'));

      // Only authenticated users can delete (UI restricts this to coordinator+).
      allow delete: if request.auth != null;
    }

    // Deny everything else by default (no catch-all rule needed — Storage
    // denies any path not matched by an explicit allow).
  }
}
