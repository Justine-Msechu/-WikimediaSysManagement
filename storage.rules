rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Evidence files ────────────────────────────────────────────────────────────
    // Path: evidence/{activityId}/{fileName}
    match /evidence/{activityId}/{fileName} {
      // Any authenticated user can read evidence files
      allow read: if request.auth != null;

      // Coordinators and admins can upload
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024  // max 20 MB
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('video/.*')
                       || request.resource.contentType == 'application/pdf'
                       || request.resource.contentType == 'text/csv'
                       || request.resource.contentType.matches('application/vnd.*'));

      allow delete: if request.auth != null;
    }
  }
}
